# =============================================
# 전세사기 위험도 분석 시스템 - 환경변수 설정
# =============================================
# 이 파일을 복사하여 .env 를 만드세요.
#   cp .env.example .env
# =============================================

# -----------------------------------------------
# 앱 환경
# -----------------------------------------------
# local | production
APP_ENV=local

# -----------------------------------------------
# MySQL 데이터베이스
# -----------------------------------------------
DB_HOST=localhost
DB_PORT=3306
DB_NAME=fraud_detector
DB_USER=root
DB_PASSWORD=your_mysql_password

# 연결 타임아웃 (초) - 선택사항 (기본값 사용 시 생략 가능)
DB_CONNECT_TIMEOUT=5
DB_READ_TIMEOUT=30

# -----------------------------------------------
# Redis
# -----------------------------------------------
# 형식: redis://:비밀번호@호스트:포트
REDIS_URL=redis://:your_redis_password@localhost:6379
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# -----------------------------------------------
# 국토교통부 공공데이터 API
# -----------------------------------------------
# 발급: https://www.data.go.kr → "아파트 전월세 실거래가" 검색 후 신청
# 인코딩된 서비스 키를 그대로 붙여넣으세요.
API_SERVICE_KEY=your_molit_api_service_key

# -----------------------------------------------
# Kakao REST API (주소 검색, 지도 서비스)
# -----------------------------------------------
# 발급: https://developers.kakao.com → 내 애플리케이션 → REST API 키
KAKAO_API_KEY=your_kakao_rest_api_key

# -----------------------------------------------
# Google Gemini API (OCR)
# -----------------------------------------------
# 발급: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key
